# приложение
APP_NAME=AdaptIQ
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# postgresql
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=adaptiq
POSTGRES_PASSWORD=adaptiq
POSTGRES_DB=adaptiq
DATABASE_URL=postgresql+asyncpg://adaptiq:adaptiq@localhost:5432/adaptiq

# neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=adaptiq12345

# redis
REDIS_URL=redis://localhost:6379/0

# celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ml
ML_DEVICE=cpu
RUBERT_MODEL_NAME=DeepPavlov/rubert-base-cased
SENTENCE_TRANSFORMER_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# frontend
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
